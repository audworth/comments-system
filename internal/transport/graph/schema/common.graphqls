scalar Time
scalar Cursor

type User {
    id: ID!
    username: String!
    displayName: String!
}

type PageInfo {
    endCursor: Cursor
    hasNextPage: Boolean!
}

type PostConnection {
    nodes: [Post!]!
    pageInfo: PageInfo!
}

type CommentConnection {
    nodes: [Comment!]!
    pageInfo: PageInfo!
}
